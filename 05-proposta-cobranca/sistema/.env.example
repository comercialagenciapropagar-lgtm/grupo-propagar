# ============================
# Cobrai.app - Configuracao
# ============================

# --- Servidor ---
PORT=3000
NODE_ENV=development

# --- Supabase ---
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_SERVICE_KEY=eyJ...sua-service-key

# --- Asaas ---
# Sandbox: https://sandbox.asaas.com/api/v3
# Producao: https://api.asaas.com/api/v3
ASAAS_API_URL=https://sandbox.asaas.com/api/v3
ASAAS_API_KEY=seu_token_asaas
ASAAS_WEBHOOK_TOKEN=token_secreto_webhook

# --- Evolution API (WhatsApp) ---
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=sua_api_key_evolution
EVOLUTION_INSTANCE=cobranca

# --- WhatsApp Business API (Meta) ---
WHATSAPP_PHONE_NUMBER_ID=seu_phone_number_id
WHATSAPP_ACCESS_TOKEN=seu_access_token

# --- Configuracoes de Cobranca ---
# Horarios dos disparos (formato HH:MM, horario de Brasilia)
COBRANCA_HORARIO_1=07:30
COBRANCA_HORARIO_2=12:00
COBRANCA_HORARIO_3=17:30
COBRANCA_HORARIO_4=20:00

# Timezone
TZ=America/Sao_Paulo
